{
  "name": "sumsel-peduli/platform-donasi",
  "type": "project",
  "description": "Platform Donasi dan Crowdfunding Lokal Yayasan Sosial Sumsel Peduli berbasis Laravel 12.",
  "keywords": ["laravel", "donasi", "crowdfunding", "sumsel"],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "barryvdh/laravel-dompdf": "^3.1",
    "doctrine/dbal": "^4.4",
    "laravel/framework": "^12.0",
    "laravel/tinker": "^2.10"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "laravel/breeze": "^2.3",
    "laravel/pint": "^1.21",
    "laravel/sail": "^1.41",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {"psr-4": {"App\\": "app/", "Database\\Factories\\": "database/factories/", "Database\\Seeders\\": "database/seeders/"}},
  "autoload-dev": {"psr-4": {"Tests\\": "tests/"}},
  "scripts": {
    "post-autoload-dump": ["Illuminate\\Foundation\\ComposerScripts::postAutoloadDump", "@php artisan package:discover --ansi"],
    "post-create-project-cmd": ["@php artisan key:generate --ansi", "@php artisan migrate --graceful --ansi"]
  },
  "extra": {"laravel": {"dont-discover": []}},
  "config": {"optimize-autoloader": true, "preferred-install": "dist", "sort-packages": true, "allow-plugins": {"pestphp/pest-plugin": true, "php-http/discovery": true}} ,
  "minimum-stability": "stable",
  "prefer-stable": true
}
